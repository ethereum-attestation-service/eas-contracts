# Copy this file to .env and fill in real values. .env is gitignored.
#
# To use these vars with hardhat in this repo without adding the dotenv dep,
# either:
#   - export the vars in your shell before running:  source .env && pnpm hardhat ...
#   - or use dotenvx: dotenvx run -f .env -- pnpm hardhat ...
#
# Required for any deploy:
DEPLOYER_PRIVATE_KEY=0x

# PulseChain mainnet (chainId 369). Override the default RPC if you have a private endpoint.
PULSECHAIN_RPC_URL=https://rpc.pulsechain.com
PULSESCAN_API_KEY=

# PulseChain testnet v4 (chainId 943).
PULSECHAIN_TESTNET_RPC_URL=https://rpc.v4.testnet.pulsechain.com
PULSESCAN_TESTNET_API_KEY=

# Solidity compiler metadata-hash setting. Defaults to 'none' (matches upstream
# EAS convention — same as every other chain in deployments/). Set to 'ipfs'
# before running `pnpm compile` if you want Sourcify full-match status on the
# resulting deployment. Note: changing this changes the deployed bytecode,
# so testnet and mainnet should both be compiled with the same value to keep
# their bytecode identical.
#   none   → no metadata trailer in bytecode (Sourcify partial match only)
#   ipfs   → IPFS multihash embedded (Sourcify full match possible)
#   bzzr1  → legacy Swarm hash (rarely needed)
BYTECODE_HASH=none
